#!/usr/bin/env sh
set -eu

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# Ensure hooks use the repo Ruby toolchain when invoked from non-login shells.
if command -v rbenv >/dev/null 2>&1; then
  eval "$(rbenv init -)" || true
fi

echo "husky(pre-commit): running cenit non-E2E test suite"
bundle exec rspec --tag ~api_journey --tag ~api_login --tag ~api_contact_flow
